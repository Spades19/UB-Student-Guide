GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=replace_with_a_long_random_secret

# Railway MySQL usually provides these automatically when you add a MySQL database.
MYSQLHOST=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
MYSQLPORT=

# Optional local aliases. The server supports both DB_* and MYSQL* names.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ub_guide_db
DB_PORT=3306
